# Firebase service account values (use full private key with newline chars escaped)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JWT signing secret
JWT_SECRET=change_this_to_a_random_secure_value

# One-time admin setup token used for initial admin registration
ADMIN_SETUP_TOKEN=one-time-setup-token

# CORS default
ALLOWED_ORIGINS=http://localhost:5173

PORT=5000
